{
    "plugins": [
        [
            "@babel/plugin-proposal-decorators",
            {
                "legacy": true
            }
        ],
        "babel-plugin-transform-typescript-metadata",
        [
            "styled-jsx/babel",
            {
                "plugins": [
                    [
                        "styled-jsx-plugin-postcss",
                        {
                            "path": ".postcssrc.json"
                        }
                    ],
                    "@styled-jsx/plugin-sass"
                ]
            }
        ]
    ],
    "presets": [
        "babel-preset-react-app/prod",
        "@babel/preset-env",
        "@babel/preset-react"
    ]
}
