{
    "devDependencies": {
        "@babel/cli": "7.21.0",
        "@babel/core": "7.21.0",
        "@babel/preset-env": "7.20.2",
        "@babel/preset-react": "7.18.6",
        "@types/eslint": "8.21.1",
        "@types/node": "18.14.0",
        "@types/react": "18.0.28",
        "@types/react-dom": "18.0.11",
        "@types/react-helmet": "6.1.6",
        "@types/sass": "1.43.1",
        "@typescript-eslint/eslint-plugin": "5.53.0",
        "@typescript-eslint/parser": "5.53.0",
        "@typescript-eslint/types": "5.53.0",
        "autoprefixer": "10.4.13",
        "babel-preset-react-app": "10.0.1",
        "browserify": "17.0.0",
        "cssnano": "5.1.15",
        "eslint": "8.34.0",
        "eslint-config-eslint": "7.0.0",
        "eslint-config-standard": "17.0.0",
        "eslint-config-standard-jsx": "11.0.0",
        "eslint-import-resolver-typescript": "3.5.3",
        "eslint-plugin-etc": "2.0.2",
        "eslint-plugin-functional": "5.0.4",
        "eslint-plugin-import": "2.27.5",
        "eslint-plugin-jsdoc": "40.0.0",
        "eslint-plugin-jsx-a11y": "6.7.1",
        "eslint-plugin-n": "15.6.1",
        "eslint-plugin-promise": "6.1.1",
        "eslint-plugin-react": "7.32.2",
        "eslint-plugin-react-hooks": "4.6.0",
        "eslint-plugin-rxjs": "5.0.2",
        "npm-run-all": "4.1.5",
        "postcss": "8.4.21",
        "postcss-cli": "10.1.0",
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "react-helmet": "6.1.0",
        "react-router": "6.8.1",
        "react-router-dom": "6.8.1",
        "rimraf": "4.1.2",
        "sass": "1.58.3",
        "scsslint": "0.0.3",
        "stylelint": "15.2.0",
        "stylelint-config-twbs-bootstrap": "7.0.0",
        "terser": "5.16.4",
        "tslib": "2.5.0",
        "typescript": "4.9.5",
        "typescript-eslint-language-service": "5.0.0"
    },
    "engines": {
        "node": ">=19"
    },
    "name": "mecha-natori.github.io",
    "private": true,
    "scripts": {
        "build": "run-p build:scss build:ts",
        "build:scss": "run-s build:scss:sass build:scss:postcss",
        "build:scss:postcss": "postcss compiled/css --dir docs/css",
        "build:scss:sass": "sass styles/:compiled/css --no-source-map",
        "build:ts": "run-s build:ts:tsc build:ts:babel build:ts:browserify build:ts:teser",
        "build:ts:babel": "babel compiled/js --out-dir docs/js",
        "build:ts:browserify": "browserify docs/js/components/* docs/js/* docs/js/pages/* -o docs/js/index.bundle.js",
        "build:ts:teser": "terser --compress --mangle --output docs/js/index.bundle.min.js -- docs/js/index.bundle.js",
        "build:ts:tsc": "tsc -b",
        "clean": "rimraf .tsbuildinfo compiled/css/* compiled/js/* docs/css/* docs/js/*"
    },
    "version": "1.0.0"
}
